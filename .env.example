# Copy this file to .env and fill in local secrets/settings.

# Harvest settings
TOPIC_OVERVIEWS_ARXIV_QUERY=
TOPIC_OVERVIEWS_ARXIV_QUERY_PROPERTY=P1965
TOPIC_OVERVIEWS_SINCE_DAYS=10
TOPIC_OVERVIEWS_HARVEST_LIMIT=0
TOPIC_OVERVIEWS_STATE_PATH=state.json
TOPIC_OVERVIEWS_RESEARCH_THEME_QID=Q7266523
TOPIC_OVERVIEWS_DRY_RUN=false

# LLM settings
TOPIC_OVERVIEWS_MODEL=claude-haiku-4-5
TOPIC_OVERVIEWS_MODEL_QID=
ANTHROPIC_API_KEY=

# MaRDI portal / Wikibase
MEDIAWIKI_API_URL=https://portal.mardi4nfdi.de/w/api.php
MEDIAWIKI_BOT_USER=
MEDIAWIKI_BOT_PASSWORD=
WIKIBASE_URL=https://portal.mardi4nfdi.de
SPARQL_ENDPOINT_URL=https://query.portal.mardi4nfdi.de/sparql
